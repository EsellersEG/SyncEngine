# Database
DATABASE_URL=postgres://user:password@localhost:5432/sync_engine

# Auth
JWT_SECRET=your_super_secret_jwt_key_here

# Server
PORT=8080
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Google Sheets API (Service Account JSON as string)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Shopify (per-store, stored in DB — these are defaults/admin)
SHOPIFY_API_VERSION=2024-10

# Amazon SP-API OAuth
APP_BASE_URL=https://syncengine-production.up.railway.app
AMAZON_APP_ID=amzn1.sp.solution.xxx
AMAZON_CLIENT_ID=amzn1.application-oa2-client.xxx
AMAZON_CLIENT_SECRET=your_amazon_client_secret

# Gemini API Key (for Marketplace Content Generator tool)
VITE_GEMINI_API_KEY=your_gemini_api_key_here
